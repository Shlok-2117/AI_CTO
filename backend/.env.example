# Supabase PostgreSQL — Transaction mode (pooler, port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Supabase PostgreSQL — Session mode (direct, port 5432) — used by Prisma migrations
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

JWT_SECRET="replace-with-64-char-random-string"
REFRESH_SECRET="replace-with-another-64-char-random-string"
OPENROUTER_API_KEY="get-from-openrouter.ai"
GEMINI_API_KEY="get-from-aistudio.google.com (optional)"
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CHROME_EXECUTABLE_PATH=""
